DATABASE_URL=sqlite:///./qubrix.db
ENV=development
SECRET_KEY=troque-esta-chave-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:4201,http://127.0.0.1:4201
APP_NAME=QuBrix
ADMIN_EMAIL=
ADMIN_PASSWORD=
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_DEFAULT=120/minute
SEED_DEMO_DATA=true

# Para apontar para o banco publicado no Render, NAO altere este arquivo:
# copie backend/.env.render.example para backend/.env.render e inicie com
#   start-backend.bat render
# Para popular dados de exemplo no Render:
#   seed-demo.bat render
# ou defina SEED_DEMO_DATA=true no painel do Render e redeploy a API (uma vez).
